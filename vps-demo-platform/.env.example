# Cloudflare API Token for Let's Encrypt DNS Challenge
# Create at: Cloudflare Dashboard -> My Profile -> API Tokens
# Permissions: Zone -> DNS -> Edit
# Zone Resources: Include -> Specific zone -> christosm.dev
CF_DNS_API_TOKEN=your_cloudflare_api_token_here

# Basic Auth for Traefik Dashboard and Prometheus
# Generate with: echo $(htpasswd -nB admin) | sed -e 's/\$/\$\$/g'
# The sed command escapes $ signs for docker-compose
TRAEFIK_BASIC_AUTH=admin:$$2y$$05$$your_hash_here
