@startuml
title <size:24>Container View: VPS Sandbox Platform</size>\n<size:24>Container diagram showing the runtime services of the VPS Sandbox Platform</size>

set separator none
top to bottom direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>

Person(DevOpsEngineer, "DevOps Engineer", $descr="Deploys and manages containerized applications on the platform", $tags="", $link="")
Person(Developer, "Developer", $descr="Executes code in sandboxed containers via the API", $tags="", $link="")
Person(TechnicalInterviewer, "Technical Interviewer", $descr="Reviews portfolio, architecture decisions, and monitoring dashboards", $tags="", $link="")
System(LetsEncrypt, "Let's Encrypt", $descr="SSL/TLS certificate provider (ACME)", $tags="", $link="")
System(Cloudflare, "Cloudflare", $descr="DNS management and CDN proxy for *.christosm.dev", $tags="", $link="")

System_Boundary("VPSSandboxPlatform_boundary", "VPS Sandbox Platform", $tags="") {
    Container(VPSSandboxPlatform.Traefik, "Traefik", $techn="Traefik v3", $descr="Reverse proxy with automatic service discovery, SSL termination, and rate limiting", $tags="", $link="")
  Container(VPSSandboxPlatform.SandboxAPI, "Sandbox API", $techn="FastAPI, Python 3.11", $descr="REST API for sandboxed code execution and container management", $tags="", $link="")
  Container(VPSSandboxPlatform.Prometheus, "Prometheus", $techn="Prometheus v2.50", $descr="Collects and stores time-series metrics from all services", $tags="", $link="")
  Container(VPSSandboxPlatform.Grafana, "Grafana", $techn="Grafana 10.3", $descr="Unified dashboards for metrics and log visualisation", $tags="", $link="")
  Container(VPSSandboxPlatform.Loki, "Loki", $techn="Grafana Loki 3.4", $descr="Log aggregation engine with label-based indexing", $tags="", $link="")
  Container(VPSSandboxPlatform.Promtail, "Promtail", $techn="Grafana Promtail 3.4", $descr="Log collection agent for Docker containers and host logs", $tags="", $link="")
  Container(VPSSandboxPlatform.Portainer, "Portainer", $techn="Portainer CE 2.11", $descr="Web-based Docker management UI for container and image operations", $tags="", $link="")
}

Rel(DevOpsEngineer, VPSSandboxPlatform.Traefik, "Manages platform via", $techn="HTTPS", $tags="", $link="")
Rel(Developer, VPSSandboxPlatform.Traefik, "Submits code for execution via", $techn="HTTPS", $tags="", $link="")
Rel(TechnicalInterviewer, VPSSandboxPlatform.Grafana, "Views metrics and logs via", $techn="HTTPS", $tags="", $link="")
Rel(TechnicalInterviewer, VPSSandboxPlatform.Traefik, "Browses API documentation via", $techn="HTTPS", $tags="", $link="")
Rel(VPSSandboxPlatform.Traefik, VPSSandboxPlatform.SandboxAPI, "Forwards API requests to", $techn="HTTP (api.christosm.dev)", $tags="", $link="")
Rel(VPSSandboxPlatform.Traefik, VPSSandboxPlatform.Grafana, "Forwards dashboard requests to", $techn="HTTP (grafana.christosm.dev)", $tags="", $link="")
Rel(VPSSandboxPlatform.Traefik, VPSSandboxPlatform.Prometheus, "Forwards metrics UI requests to", $techn="HTTP (prometheus.christosm.dev)", $tags="", $link="")
Rel(VPSSandboxPlatform.Traefik, VPSSandboxPlatform.Portainer, "Forwards management requests to", $techn="HTTP (portainer.christosm.dev)", $tags="", $link="")
Rel(VPSSandboxPlatform.Traefik, LetsEncrypt, "Requests certificates via", $techn="ACME / Cloudflare DNS challenge", $tags="", $link="")
Rel(VPSSandboxPlatform.Traefik, Cloudflare, "Validates domain ownership via", $techn="DNS-01 challenge", $tags="", $link="")
Rel(VPSSandboxPlatform.Prometheus, VPSSandboxPlatform.SandboxAPI, "Scrapes metrics from", $techn="HTTP /metrics", $tags="", $link="")
Rel(VPSSandboxPlatform.Prometheus, VPSSandboxPlatform.Traefik, "Scrapes metrics from", $techn="HTTP :8080/metrics", $tags="", $link="")
Rel(VPSSandboxPlatform.Prometheus, VPSSandboxPlatform.Loki, "Scrapes metrics from", $techn="HTTP :3100/metrics", $tags="", $link="")
Rel(VPSSandboxPlatform.Grafana, VPSSandboxPlatform.Prometheus, "Queries metrics from", $techn="PromQL", $tags="", $link="")
Rel(VPSSandboxPlatform.Grafana, VPSSandboxPlatform.Loki, "Queries logs from", $techn="LogQL", $tags="", $link="")
Rel(VPSSandboxPlatform.Promtail, VPSSandboxPlatform.Loki, "Pushes log streams to", $techn="HTTP /loki/api/v1/push", $tags="", $link="")
Rel(VPSSandboxPlatform.SandboxAPI, VPSSandboxPlatform.Prometheus, "Exposes metrics to", $techn="HTTP", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml
