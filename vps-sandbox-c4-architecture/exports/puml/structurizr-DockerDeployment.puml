@startuml
title <size:24>Deployment View: VPS Sandbox Platform - Live</size>\n<size:24>Current deployment: Docker containers on Contabo VPS with Traefik edge routing</size>

set separator none
top to bottom direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Deployment>

Deployment_Node(Live.ContaboVPS, "Contabo VPS", $type="Physical Server", $descr="Ubuntu 22.04 LTS, 8GB RAM, 4 vCPU", $tags="", $link="") {
  Deployment_Node(Live.ContaboVPS.DockerEngine, "Docker Engine", $type="Docker 29.x", $descr="Container runtime with bridge networking", $tags="", $link="") {
    Container(Live.ContaboVPS.DockerEngine.Traefik_1, "Traefik", $techn="Traefik v3", $descr="Reverse proxy with automatic service discovery, SSL termination, and rate limiting", $tags="", $link="")
    Container(Live.ContaboVPS.DockerEngine.SandboxAPI_1, "Sandbox API", $techn="FastAPI, Python 3.11", $descr="REST API for sandboxed code execution and container management", $tags="", $link="")
    Container(Live.ContaboVPS.DockerEngine.Prometheus_1, "Prometheus", $techn="Prometheus v2.50", $descr="Collects and stores time-series metrics from all services", $tags="", $link="")
    Container(Live.ContaboVPS.DockerEngine.Grafana_1, "Grafana", $techn="Grafana 10.3", $descr="Unified dashboards for metrics and log visualisation", $tags="", $link="")
    Container(Live.ContaboVPS.DockerEngine.Loki_1, "Loki", $techn="Grafana Loki 3.4", $descr="Log aggregation engine with label-based indexing", $tags="", $link="")
    Container(Live.ContaboVPS.DockerEngine.Promtail_1, "Promtail", $techn="Grafana Promtail 3.4", $descr="Log collection agent for Docker containers and host logs", $tags="", $link="")
    Container(Live.ContaboVPS.DockerEngine.Portainer_1, "Portainer", $techn="Portainer CE 2.11", $descr="Web-based Docker management UI for container and image operations", $tags="", $link="")
  }

}

Rel(Live.ContaboVPS.DockerEngine.Traefik_1, Live.ContaboVPS.DockerEngine.SandboxAPI_1, "Forwards API requests to", $techn="HTTP (api.christosm.dev)", $tags="", $link="")
Rel(Live.ContaboVPS.DockerEngine.Prometheus_1, Live.ContaboVPS.DockerEngine.Traefik_1, "Scrapes metrics from", $techn="HTTP :8080/metrics", $tags="", $link="")
Rel(Live.ContaboVPS.DockerEngine.Traefik_1, Live.ContaboVPS.DockerEngine.Prometheus_1, "Forwards metrics UI requests to", $techn="HTTP (prometheus.christosm.dev)", $tags="", $link="")
Rel(Live.ContaboVPS.DockerEngine.Prometheus_1, Live.ContaboVPS.DockerEngine.SandboxAPI_1, "Scrapes metrics from", $techn="HTTP /metrics", $tags="", $link="")
Rel(Live.ContaboVPS.DockerEngine.SandboxAPI_1, Live.ContaboVPS.DockerEngine.Prometheus_1, "Exposes metrics to", $techn="HTTP", $tags="", $link="")
Rel(Live.ContaboVPS.DockerEngine.Traefik_1, Live.ContaboVPS.DockerEngine.Grafana_1, "Forwards dashboard requests to", $techn="HTTP (grafana.christosm.dev)", $tags="", $link="")
Rel(Live.ContaboVPS.DockerEngine.Grafana_1, Live.ContaboVPS.DockerEngine.Prometheus_1, "Queries metrics from", $techn="PromQL", $tags="", $link="")
Rel(Live.ContaboVPS.DockerEngine.Prometheus_1, Live.ContaboVPS.DockerEngine.Loki_1, "Scrapes metrics from", $techn="HTTP :3100/metrics", $tags="", $link="")
Rel(Live.ContaboVPS.DockerEngine.Grafana_1, Live.ContaboVPS.DockerEngine.Loki_1, "Queries logs from", $techn="LogQL", $tags="", $link="")
Rel(Live.ContaboVPS.DockerEngine.Promtail_1, Live.ContaboVPS.DockerEngine.Loki_1, "Pushes log streams to", $techn="HTTP /loki/api/v1/push", $tags="", $link="")
Rel(Live.ContaboVPS.DockerEngine.Traefik_1, Live.ContaboVPS.DockerEngine.Portainer_1, "Forwards management requests to", $techn="HTTP (portainer.christosm.dev)", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml