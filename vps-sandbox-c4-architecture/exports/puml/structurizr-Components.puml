@startuml
title <size:24>Component View: VPS Sandbox Platform - Sandbox API</size>\n<size:24>Component diagram showing the internal structure of the Sandbox API</size>

set separator none
top to bottom direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>
!include <C4/C4_Component>

System_Boundary("VPSSandboxPlatform_boundary", "VPS Sandbox Platform", $tags="") {
  Container_Boundary("VPSSandboxPlatform.SandboxAPI_boundary", "Sandbox API", $tags="") {
    Component(VPSSandboxPlatform.SandboxAPI.ExecutionRoutes, "Execution Routes", $techn="FastAPI Router", $descr="Handles code execution requests (/execute endpoint)", $tags="", $link="")
    Component(VPSSandboxPlatform.SandboxAPI.HealthCheckRoutes, "Health Check Routes", $techn="FastAPI Router", $descr="Provides health and readiness endpoints (/health, /ready)", $tags="", $link="")
    Component(VPSSandboxPlatform.SandboxAPI.MetricsEndpoint, "Metrics Endpoint", $techn="Prometheus Client", $descr="Exposes Prometheus metrics at /metrics", $tags="", $link="")
    Component(VPSSandboxPlatform.SandboxAPI.SandboxManager, "Sandbox Manager", $techn="Python Service", $descr="Orchestrates ephemeral container lifecycle: create, execute, destroy", $tags="", $link="")
    Component(VPSSandboxPlatform.SandboxAPI.SecurityManager, "Security Manager", $techn="Python Service", $descr="Enforces resource limits, network isolation, and capability restrictions", $tags="", $link="")
    Component(VPSSandboxPlatform.SandboxAPI.DockerClient, "Docker Client", $techn="Docker SDK for Python", $descr="Wraps Docker Engine API for container operations", $tags="", $link="")
  }

  Container(VPSSandboxPlatform.Prometheus, "Prometheus", $techn="Prometheus v2.50", $descr="Collects and stores time-series metrics from all services", $tags="", $link="")
}

Rel(VPSSandboxPlatform.SandboxAPI.ExecutionRoutes, VPSSandboxPlatform.SandboxAPI.SandboxManager, "Delegates execution to", $techn="", $tags="", $link="")
Rel(VPSSandboxPlatform.SandboxAPI.ExecutionRoutes, VPSSandboxPlatform.SandboxAPI.SecurityManager, "Validates request limits via", $techn="", $tags="", $link="")
Rel(VPSSandboxPlatform.SandboxAPI.HealthCheckRoutes, VPSSandboxPlatform.SandboxAPI.DockerClient, "Checks Docker connectivity via", $techn="", $tags="", $link="")
Rel(VPSSandboxPlatform.SandboxAPI.SandboxManager, VPSSandboxPlatform.SandboxAPI.SecurityManager, "Applies security constraints via", $techn="", $tags="", $link="")
Rel(VPSSandboxPlatform.SandboxAPI.SandboxManager, VPSSandboxPlatform.SandboxAPI.DockerClient, "Creates and manages ephemeral containers via", $techn="", $tags="", $link="")
Rel(VPSSandboxPlatform.SandboxAPI.MetricsEndpoint, VPSSandboxPlatform.Prometheus, "Exposes metrics to", $techn="HTTP", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml