@startuml
title <size:24>Dynamic View: VPS Sandbox Platform</size>\n<size:24>Resource monitoring flow</size>

set separator none
top to bottom direction

<style>
  root {
    BackgroundColor: #ffffff
    FontColor: #444444
  }
</style>

!include <C4/C4>
!include <C4/C4_Context>
!include <C4/C4_Container>

System_Boundary("VPSSandboxPlatform_boundary", "VPS Sandbox Platform", $tags="") {
  Container(VPSSandboxPlatform.Prometheus, "Prometheus", $techn="Prometheus", $descr="Collects and stores metrics from all containers", $tags="", $link="")
  Container(VPSSandboxPlatform.Grafana, "Grafana", $techn="Grafana", $descr="Visualizes metrics and provides monitoring dashboards", $tags="", $link="")
  Container(VPSSandboxPlatform.BackendAPI, "Backend API", $techn="FastAPI, Python 3.11", $descr="Provides REST API for container management and monitoring", $tags="", $link="")
}

Person(TechnicalInterviewer, "Technical Interviewer", $descr="Reviews portfolio and architecture decisions", $tags="", $link="")

Rel(VPSSandboxPlatform.Prometheus, VPSSandboxPlatform.BackendAPI, "1: 1. Scrape metrics", $techn="HTTP/Prometheus", $tags="", $link="")
Rel(VPSSandboxPlatform.BackendAPI, VPSSandboxPlatform.Prometheus, "2: 2. Expose container metrics", $techn="HTTP", $tags="", $link="")
Rel(VPSSandboxPlatform.Grafana, VPSSandboxPlatform.Prometheus, "3: 3. Query metrics", $techn="PromQL", $tags="", $link="")
Rel(VPSSandboxPlatform.Prometheus, VPSSandboxPlatform.Grafana, "4: 4. Return time-series data", $techn="PromQL", $tags="", $link="")
Rel(TechnicalInterviewer, VPSSandboxPlatform.Grafana, "5: 5. View dashboard", $techn="HTTPS", $tags="", $link="")

SHOW_LEGEND(true)
hide stereotypes
@enduml