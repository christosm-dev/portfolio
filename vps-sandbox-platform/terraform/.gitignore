# Terraform state (contains sensitive data)
*.tfstate
*.tfstate.*

# Terraform working directory
.terraform/

# Terraform lock file (optional - some teams commit this)
# .terraform.lock.hcl

# Variable files with secrets
terraform.tfvars
*.tfvars
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
