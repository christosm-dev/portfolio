      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by(http_status) (increase(http_requests_total[1h]))",
          "legendFormat": "HTTP {{http_status}}",
          "refId": "A",
